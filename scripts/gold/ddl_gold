/*
===============================================================================
DDL Script: Create Gold Views 
===============================================================================
Script Purpose:
    This script creates views for the Gold layer in the data warehouse. 
    The Gold layer represents the final dimension and fact tables (Star Schema).

    Each view performs transformations and combines data from the Silver layer 
    to produce a clean, enriched, and business-ready dataset.

Usage:
    - These views can be queried directly for analytics and reporting.
===============================================================================
*/

CREATE OR REPLACE PROCEDURE create_gold_views()
LANGUAGE plpgsql 
AS $$
BEGIN
RAISE NOTICE 'CREATE VIEW gold.dim_customers';

CREATE OR REPLACE VIEW gold.dim_customers AS 
SELECT 
		ROW_NUMBER() OVER( ORDER BY ci.cst_key ASC) AS customer_key,ci.cst_id AS customer_id,
		ci.cst_key AS customer_number,ci.cst_firstname AS first_name,ci.cst_lastname AS last_name,
		cst_marital_status AS marital_status,
		ca.bdate AS birthdate,
		CASE 
		WHEN ci.cst_gndr ='n/a' THEN ca.gen
		ELSE ci.cst_gndr
		END AS gender,
		la.cntry as country,
		cst_create_date AS create_date


		FROM silver.crm_cust_info ci
		JOIN silver.erp_cust_az12 ca
		ON ci.cst_key=ca.cid
		JOIN silver.erp_loc_a101 la
		ON ci.cst_key=la.cid;

		RAISE NOTICE 'CREATE VIEW gold.dim_products';

CREATE OR REPLACE VIEW gold.dim_products AS
	SELECT 
		ROW_NUMBER() OVER( ORDER BY pn.prd_start_dt ASC) AS product_key,pn.prd_id AS product_id,
		pn.cat_id AS category_id, pn.prd_key AS product_number, pn.prd_nm AS product_name,
		pc.cat AS category,pc.subcat AS subcategory,pc.maintenance,
		pn.prd_cost AS product_cost, pn.prd_line AS product_line,pn.prd_start_dt AS start_date

	FROM silver.crm_prd_info pn 
	JOIN silver.erp_px_cat_g1v2 pc
	ON pn.cat_id=pc.id

		RAISE NOTICE 'CREATE VIEW gold.fact_sales';

CREATE OR REPLACE VIEW gold.fact_sales AS
	SELECT 
		cs.sls_ord_num AS order_number,
		dp.product_key,
		dc.customer_key,
		cs.sls_order_dt AS order_date,
		cs.sls_ship_dt AS ship_date,
		cs.sls_due_dt AS due_date,
		cs.sls_sales AS sales_amount,
		cs.sls_quantity AS sales_quantity,
		cs.sls_price AS price

	FROM silver.crm_sales_details cs
		JOIN gold.dim_customers dc
		ON cs.sls_cust_id=dc.customer_id
		JOIN gold.dim_products dp
		ON dp.product_number=cs.sls_prd_key;
END;
$$;
